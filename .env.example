# Copy to .env
DATABASE_URL="file:./dev.db"
PORT=4000
NODE_ENV=development
JWT_SECRET="change-me-to-a-long-random-string-for-production-use-only"
JWT_EXPIRES_IN="7d"

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# --- n8n integration ---
# Shared secret. n8n must send this as the "x-ingest-key" header when it
# POSTs incoming messages to /api/ingest. Use a long random string.
INGEST_API_KEY=""
# The n8n webhook URL the app POSTs outbound replies (Telegram/Email) to.
N8N_OUTBOUND_WEBHOOK_URL=""
