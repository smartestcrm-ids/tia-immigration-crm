# Copy to .env for local development. In production these are set in Coolify.
#
# Local dev (SQLite, for quick local testing):
#   DATABASE_URL="file:./dev.db"
# Production (PostgreSQL on the VPS — what Coolify sets):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/immigration_crm"

PORT=4000
NODE_ENV=development
JWT_SECRET="change-me-to-a-long-random-string-for-production-use-only"
JWT_EXPIRES_IN="7d"

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# --- n8n integration ---
# Shared secret. n8n must send this as the "x-ingest-key" header when it
# POSTs incoming messages to /api/ingest. Use a long random string.
INGEST_API_KEY=""
# The n8n webhook URL the app POSTs outbound replies (Telegram/Email) to.
N8N_OUTBOUND_WEBHOOK_URL=""

# --- Outbound email (SMTP) ---
# Used by the "Send Email" button on the LeadDetail page.
# For Gmail: create an APP PASSWORD (Google Account -> Security -> 2FA -> App passwords).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="Tia Immigration"
