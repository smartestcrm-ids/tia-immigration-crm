// Prisma schema for Phase 1 - Unified Inbox + CRM
// Production: PostgreSQL on the VPS. Field types remain Postgres-compatible.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Roles & Permissions
// -----------------------------------------------------------------------------

model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  description String
  category    String
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]
}

model RolePermission {
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// -----------------------------------------------------------------------------
// Users (consultants & admins)
// -----------------------------------------------------------------------------

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String
  role          String    @default("CONSULTANT")
  roleId        Int?
  roleRef       Role?     @relation(fields: [roleId], references: [id])
  passwordHash  String?
  active        Boolean   @default(true)
  // Protected users cannot be disabled, role-changed, or deleted via the API.
  // Use for system / owner accounts that should never be lost by accident.
  isProtected   Boolean   @default(false)
  // Hidden users do not appear in the Users list or in assignment dropdowns.
  // Only the user themselves can see their own record.
  hidden        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedLeads     Lead[]     @relation("LeadAssignedTo")
  notes             Note[]
  reminders         Reminder[]
  uploadedDocuments Document[] @relation("DocumentUploadedBy")
  managedCases      Case[]     @relation("CaseManager")
  completedStages   CaseStageEvent[] @relation("CaseStageCompletedBy")
}

// -----------------------------------------------------------------------------
// Case Types
// -----------------------------------------------------------------------------

model CaseType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  leads Lead[]
  cases Case[]
}

// -----------------------------------------------------------------------------
// Leads
// -----------------------------------------------------------------------------

model Lead {
  id                Int       @id @default(autoincrement())
  fullName          String
  email             String?
  phone             String?

  source            String
  status            String    @default("NEW")

  caseTypeId        Int?
  caseType          CaseType? @relation(fields: [caseTypeId], references: [id])

  assignedToId      Int?
  assignedTo        User?     @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  externalContactId String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  conversations Conversation[]
  notes         Note[]
  reminders     Reminder[]
  clientProfile ClientProfile?
  case          Case?

  @@unique([source, externalContactId], name: "uniq_lead_per_channel_contact")
  @@index([assignedToId, status])
  @@index([status])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Channel Accounts (multiple per channel)
// -----------------------------------------------------------------------------

model ChannelAccount {
  id          Int      @id @default(autoincrement())
  channel     String   // WHATSAPP | EMAIL | TELEGRAM | INSTAGRAM | SMS | WEB_FORM
  label       String   // e.g. "Toronto WhatsApp", "info@firm.com"
  identifier  String   // unique per channel: phone number, email, handle, bot name
  config      String?  // JSON: channel-specific config (api keys, etc.)
  active      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]

  @@unique([channel, identifier], name: "uniq_channel_identifier")
}

// -----------------------------------------------------------------------------
// Conversations & Messages
// -----------------------------------------------------------------------------

model Conversation {
  id               Int       @id @default(autoincrement())
  leadId           Int
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel          String
  externalThreadId String?

  channelAccountId Int?
  channelAccount   ChannelAccount? @relation(fields: [channelAccountId], references: [id])

  lastMessageAt    DateTime  @default(now())
  unreadCount      Int       @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages Message[]

  @@index([lastMessageAt])
  @@index([leadId])
  @@index([channel])
}

model Message {
  id                Int       @id @default(autoincrement())
  conversationId    Int
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction         String
  channel           String
  body              String
  externalMessageId String?   @unique
  status            String    @default("RECEIVED")

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([conversationId, sentAt])
}

// -----------------------------------------------------------------------------
// Notes & Reminders
// -----------------------------------------------------------------------------

model Note {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  Int?
  author    User?    @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model Reminder {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ownerId   Int?
  owner     User?    @relation(fields: [ownerId], references: [id])
  title     String
  dueAt     DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, completed, dueAt])
  @@index([leadId])
}

// -----------------------------------------------------------------------------
// Client Profile, Family Members, Documents
// (Created once a Lead becomes CONVERTED)
// -----------------------------------------------------------------------------

model ClientProfile {
  id     Int  @id @default(autoincrement())
  leadId Int  @unique
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  dateOfBirth    DateTime?
  nationality    String?
  passportNumber String?
  passportExpiry DateTime?
  address        String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  familyMembers FamilyMember[]
  documents     Document[]
}

model FamilyMember {
  id              Int           @id @default(autoincrement())
  clientProfileId Int
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  relation       String  // SPOUSE | CHILD | PARENT | SIBLING | OTHER
  fullName       String
  dateOfBirth    DateTime?
  nationality    String?
  passportNumber String?
  passportExpiry DateTime?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]

  @@index([clientProfileId])
}

// -----------------------------------------------------------------------------
// Cases — post-contract workflow (12-stage pipeline for CONVERTED leads)
// -----------------------------------------------------------------------------

model Case {
  id     Int  @id @default(autoincrement())
  leadId Int  @unique
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  caseTypeId Int?
  caseType   CaseType? @relation(fields: [caseTypeId], references: [id])

  // See CASE_STAGES in src/caseTemplates.js
  currentStage String @default("SIGNED")
  // ACTIVE | ON_HOLD | SUBMITTED | CLOSED
  status       String @default("ACTIVE")

  caseManagerId Int?
  caseManager   User? @relation("CaseManager", fields: [caseManagerId], references: [id])

  // Financial (from the requirements doc's Client Workflow)
  agreementAmount Float?
  amountPaid      Float?
  currency        String   @default("CAD")
  agreementDate   DateTime?

  notes String?

  openedAt    DateTime  @default(now())
  submittedAt DateTime?
  closedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageHistory CaseStageEvent[]
  requirements DocumentRequirement[]

  @@index([status])
  @@index([caseManagerId])
}

model CaseStageEvent {
  id            Int      @id @default(autoincrement())
  caseId        Int
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stage         String
  // COMPLETED | SKIPPED | UNDONE
  status        String   @default("COMPLETED")
  completedAt   DateTime @default(now())
  completedById Int?
  completedBy   User?    @relation("CaseStageCompletedBy", fields: [completedById], references: [id])
  notes         String?

  @@index([caseId, completedAt])
}

model DocumentRequirement {
  id     Int  @id @default(autoincrement())
  caseId Int
  case   Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  name     String
  category String? // IDENTITY | EDUCATION | FINANCIAL | LEGAL | OTHER
  // PENDING | REQUESTED | RECEIVED | MISSING | NA
  status   String  @default("PENDING")

  requiredForApplicant Boolean @default(true)
  familyMemberName     String? // free-text, for family members if applicable

  documentId Int?
  document   Document? @relation("RequirementDocument", fields: [documentId], references: [id])

  requestedAt DateTime?
  receivedAt  DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId, status])
}

model Document {
  id            Int    @id @default(autoincrement())
  filename      String
  mimeType      String
  size          Int
  category      String // PASSPORT | BIRTH_CERT | MARRIAGE_CERT | IELTS | OTHER
  contentBase64 String // base64-encoded file content

  clientProfileId Int?
  clientProfile   ClientProfile? @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  familyMemberId Int?
  familyMember   FamilyMember? @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  uploadedById Int?
  uploadedBy   User? @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  fulfillsRequirements DocumentRequirement[] @relation("RequirementDocument")

  createdAt DateTime @default(now())

  @@index([clientProfileId])
  @@index([familyMemberId])
}
